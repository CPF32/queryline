# Copy to .env before: docker compose --profile ollama up -d --build

# Host port for the web app
APP_PORT=5001

# Server auth — reverse proxy should set X-Remote-User (Kerberos/AD/LDAP SSO)
AUTH_MODE=trusted_proxy
AUTH_ADMIN_USERS=YOURDOMAIN\admin1

# Required for password sign-in if enabled
SECRET_KEY=change-me-to-a-long-random-string

# Generate once and keep stable:
# python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
FERNET_KEY=

# Metadata DB (default SQLite on the app-data volume is fine for single-container deploys)
# DATABASE_URL=postgresql+psycopg2://analytics:analytics@postgres:5432/analytics

# LLM — local Ollama sidecar (recommended for air-gapped / on-prem)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
OLLAMA_HOST_PORT=11434

# Or cloud LLM instead of Ollama:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-key
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-key
