# LLM provider: anthropic | gemini | openai | ollama
LLM_PROVIDER=gemini

# Gemini (when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-lite

# Anthropic (when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (when LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Ollama (when LLM_PROVIDER=ollama) — local inference, no API key
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3-coder:30b

# App metadata store
DATABASE_URL=sqlite:///text_to_sql_admin.db

# Authentication
# system — desktop / single-user installs; sign-in verifies the computer login password
# trusted_proxy — use X-Remote-User from reverse proxy (AD/Kerberos SSO on Linux server)
# disabled — no auth (development only)
AUTH_MODE=system
# Comma-separated admin usernames (DOMAIN\user or user@domain formats supported)
AUTH_ADMIN_USERS=

# Username/password sign-in overrides (optional)
# Active Directory / LDAP bind (server deployments)
# AUTH_LDAP_SERVER=ldap://dc.example.com
# AUTH_LDAP_BIND_DN={domain}\{username}
# AUTH_LDAP_USE_SSL=false
# Dev-only shared password when LDAP is not configured (AUTH_MODE=disabled uses "dev" by default)
# AUTH_DEV_PASSWORD=dev

# Flask session signing (required for password sign-in)
SECRET_KEY=

# Stable key for encrypting data-source passwords (generate once)
FERNET_KEY=

# Flask
PORT=5001

# Desktop app user data directory (set automatically by the Electron shell)
# APP_DATA_DIR=
# DESKTOP_RUNTIME=1
